# Shared runtime
NODE_ENV=production

# Compose service ports
WEB_PORT=3000
SERVER_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379

# Postgres container credentials (used by compose services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=muzi_db

# App runtime
DATABASE_URL=postgresql://postgres:change-me@db:5432/muzi_db
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://your-domain.example
NEXT_PUBLIC_SOCKET_URL=https://your-domain.example
CORS_ORIGIN=https://your-domain.example

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ACR image coordinates for compose.prod.yaml
ACR_LOGIN_SERVER=muziregistry.azurecr.io
WEB_IMAGE=muzi-web
SERVER_IMAGE=muzi-server
MIGRATOR_IMAGE=muzi-migrator
