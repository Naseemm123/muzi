NODE_ENV=production

# Public base URL of web app (must match deployed domain)
BETTER_AUTH_URL=https://your-domain.example

# Public socket endpoint consumed by browser client
NEXT_PUBLIC_SOCKET_URL=https://your-domain.example

# Database connection (used by better-auth + drizzle via web runtime)
DATABASE_URL=postgresql://postgres:change-me@db:5432/muzi_db

# Auth secret used by better-auth
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
